{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["agents/**/*.ts", "config/**/*.ts", "db/**/*.ts", "reporters/**/*.ts", "scripts/**/*.ts", "utils/**/*.ts", "types/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
